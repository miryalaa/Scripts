# =============================================
# Delete .log files older than 7 days in D:\Evenviewerlogs
# =============================================

$LogPath = "D:\Evenviewerlogs"
$DaysToKeep = 7

# Calculate cutoff date (files older than 7 days)
$CutoffDate = (Get-Date).AddDays(-$DaysToKeep)

Write-Host "=== Log Files Cleanup Script ===" -ForegroundColor Cyan
Write-Host "Target Folder : $LogPath" -ForegroundColor White
Write-Host "Deleting .log files older than $DaysToKeep days" -ForegroundColor Yellow

# ==================== Directory Check ====================
if (-Not (Test-Path -Path $LogPath)) {
    Write-Host "ERROR: Directory does not exist!" -ForegroundColor Red
    Write-Host "Path: $LogPath" -ForegroundColor Red
    Write-Host "Please create the folder or correct the path and try again." -ForegroundColor Yellow
    exit 1
}

Write-Host "Directory found. Proceeding with cleanup..." -ForegroundColor Green

# ==================== Find and Delete Old Log Files ====================
try {
    $FilesToDelete = Get-ChildItem -Path $LogPath -Filter "*.log" -File -Recurse -ErrorAction SilentlyContinue |
                     Where-Object { $_.LastWriteTime -lt $CutoffDate }

    if ($FilesToDelete.Count -eq 0) {
        Write-Host "`nNo log files older than $DaysToKeep days were found." -ForegroundColor Green
    }
    else {
        Write-Host "`nFound $($FilesToDelete.Count) old log files to delete." -ForegroundColor Yellow
        
        $DeletedCount = 0
        
        foreach ($file in $FilesToDelete) {
            try {
                Remove-Item -Path $file.FullName -Force -ErrorAction Stop
                Write-Host "Deleted: $($file.FullName)" -ForegroundColor Gray
                $DeletedCount++
            }
            catch {
                Write-Host "Failed to delete: $($file.FullName)" -ForegroundColor Red
                Write-Host "   Error: $($_.Exception.Message)" -ForegroundColor Red
            }
        }
        
        Write-Host "`nCleanup completed successfully!" -ForegroundColor Green
        Write-Host "Total log files deleted: $DeletedCount" -ForegroundColor Green
    }
}
catch {
    Write-Host "`nAn unexpected error occurred during cleanup:" -ForegroundColor Red
    Write-Host $_.Exception.Message -ForegroundColor Red
}

Write-Host "`nScript finished at $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')" -ForegroundColor Cyan
